# ─────────────────────────────────────────────────────────────────────────────
# KAVIN ORGANICS — .env.local
# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Your production URL (no trailing slash). Used in emails, sitemap, WA links.
# For local dev use: http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/kavin_organics?retryWrites=true&w=majority

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Secret key used to sign admin JWT tokens. Use a long random string (32+ chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Default admin credentials (used by /api/admin/seed on first setup only)
ADMIN_EMAIL=admin@kavin-organics.com
ADMIN_DEFAULT_PASSWORD=admin123

# Secret key to protect the seed endpoint (prevents anyone from calling it)
# Use any long random string
ADMIN_SEED_KEY=your_seed_secret_key_change_this

# ── Cloudinary (product image uploads) ───────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (online payments) ────────────────────────────────────────────────
# Get from razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) for development, live keys (rzp_live_...) for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get from razorpay.com → Settings → Webhooks (create a webhook, copy the secret)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Twilio (OTP SMS + WhatsApp notifications) ─────────────────────────────────
# Get from twilio.com → Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio phone number for sending OTP SMS (format: +1234567890)
TWILIO_PHONE_NUMBER=+1234567890

# Your Twilio WhatsApp sender number (format: +14155238886 for sandbox)
# For production: get a WhatsApp Business approved number from Twilio
TWILIO_WHATSAPP_FROM=+14155238886

# Your own WhatsApp number to receive admin order notifications
# Format: +919876543210 (with country code, no spaces)
ADMIN_WHATSAPP_NUMBER=+919876543210

# ── Email / SMTP (order confirmation emails) ──────────────────────────────────
# Using Gmail with App Password (recommended for small stores)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Select "Mail" and "Other (Custom name)" → copy the 16-char password
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# These are used in lib/notifications.ts (some routes use SMTP_USER instead)
SMTP_USER=your_gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587