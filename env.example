# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://kavinorganics.in
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/kavin-organics?retryWrites=true&w=majority

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=your-very-long-random-secret-here
ADMIN_SEED_KEY=another-random-secret-for-seeding
ADMIN_EMAIL=admin@kavinorganics.in
ADMIN_DEFAULT_PASSWORD=use-a-strong-password-here

# ── Cloudinary (product images) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Razorpay (payment) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Get from Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Public key exposed to browser (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ── Twilio (WhatsApp notifications) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# WhatsApp sandbox: whatsapp:+14155238886
# Production: your approved WhatsApp sender number
TWILIO_WHATSAPP_FROM=+14155238886
# Admin's WhatsApp number to receive order alerts
ADMIN_WHATSAPP_NUMBER=+919876543210

# ── Email (SMTP via Gmail App Password) ───────────────────────────────────────
# Enable 2FA on Gmail → App Passwords → generate one
SMTP_EMAIL=hello@kavinorganics.in
SMTP_PASS=your-16-char-gmail-app-password

# ── GST (India) ───────────────────────────────────────────────────────────────
# Your store's GSTIN — display only, not used for calculation currently
NEXT_PUBLIC_GSTIN=33XXXXX0000X1ZX

# ── Vercel / Deployment ───────────────────────────────────────────────────────
# Set automatically by Vercel — only needed for local testing
# VERCEL_URL=your-deployment.vercel.app